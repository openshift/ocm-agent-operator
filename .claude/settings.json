{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(make lint)",
      "Bash(make go-test)",
      "Bash(make test)",
      "Bash(make go-build)",
      "Bash(make manifests)",
      "Bash(make generate)",
      "Bash(make tools)",
      "Bash(make coverage)",
      "Bash(make install)",
      "Bash(make uninstall)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go mod *)",
      "Bash(go list *)",
      "Bash(ginkgo *)",
      "Bash(golangci-lint *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl explain *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr create *)",
      "Bash(gh pr checkout *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh run view *)",
      "Bash(gh api repos/*/pulls/*)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(which *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ]
  },
  "env": {
    "GOLANGCI_LINT_CONFIG": "boilerplate/openshift/golang-osd-operator/golangci.yml",
    "GINKGO_EDITOR_INTEGRATION": "true"
  }
}
